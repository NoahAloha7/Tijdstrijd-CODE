uint8_t reverseBits(uint8_t b) {
  b = (b & 0xF0) >> 4 | (b & 0x0F) << 4;
  b = (b & 0xCC) >> 2 | (b & 0x33) << 2;
  b = (b & 0xAA) >> 1 | (b & 0x55) << 1;
  return b;
}

void drawChar(int dev, char c, bool highlight) {
  for (int r = 0; r < 8; r++) {
    uint8_t row = 0;
    if (c >= 'A' && c <= 'Z') row = pgm_read_byte(&(font[c - 'A'][r]));
    if (rotateMatrix180) lc.setRow(dev, 7 - r, reverseBits(row));
    else lc.setRow(dev, r, row);
  }
  if (highlight) lc.setRow(dev, rotateMatrix180 ? 0 : 7, 0xFF);
}

void drawSolvedBorder() {
  for (int dev = 0; dev < NUM_DEVICES; dev++) {
    for (int row = 0; row < 8; row++) {
      uint8_t line = (row == 0 || row == 7) ? 0xFF : 0x81;
      if (rotateMatrix180) lc.setRow(dev, 7 - row, reverseBits(line));
      else lc.setRow(dev, row, line);
    }
  }
}

void displayWord() {
  if (wordSolved) return;
  drawChar(0, options0[optIndex[0]], cursorPos == 0);
  drawChar(1, options1[optIndex[1]], cursorPos == 1);
  drawChar(2, options2[optIndex[2]], cursorPos == 2);
  drawChar(3, options3[optIndex[3]], cursorPos == 3);
}

int readJoystick() {
  int x = analogRead(JOY_X);
  int y = analogRead(JOY_Y);
  int dx = x - JOY_CENTER_X;
  int dy = y - JOY_CENTER_Y;

  if (abs(dx) < DEADZONE && abs(dy) < DEADZONE) {
    axisLock = AXIS_NONE;
    return JOY_NONE;
  }

  if (axisLock == AXIS_NONE) {
    if (abs(dx) > abs(dy)) axisLock = AXIS_HORIZONTAL;
    else axisLock = AXIS_VERTICAL;
  }

  if (axisLock == AXIS_HORIZONTAL) {
    if (dx > DEADZONE) return JOY_RIGHT;
    if (dx < -DEADZONE) return JOY_LEFT;
  }

  if (axisLock == AXIS_VERTICAL) {
    if (dy > DEADZONE) return JOY_DOWN;
    if (dy < -DEADZONE) return JOY_UP;
  }

  return JOY_NONE;
}

void changeLetter(int dir) {
  int* idx = &optIndex[cursorPos];
  int maxLen = (cursorPos == 0) ? OPTIONS0_LEN : (cursorPos == 1) ? OPTIONS1_LEN : (cursorPos == 2) ? OPTIONS2_LEN : OPTIONS3_LEN;
  *idx = (*idx + dir + maxLen) % maxLen;
}

void handleJoystick() {
  if (wordSolved) return;
  if (millis() - lastJoyTime < JOY_DELAY) return;

  int dir = readJoystick();
  if (dir == lastDir || dir == JOY_NONE) {
    lastDir = dir;
    return;
  }

  lastDir = dir;
  lastJoyTime = millis();

  if (dir == JOY_LEFT) cursorPos = (cursorPos + 3) % 4;
  else if (dir == JOY_RIGHT) cursorPos = (cursorPos + 1) % 4;
  else if (dir == JOY_UP) changeLetter(1);
  else if (dir == JOY_DOWN) changeLetter(-1);

  displayWord();
}

void registerInput(int button) {
  if (morseSolved) return;

  userSequence[morseBufPos] = button;
  morseBufPos = (morseBufPos + 1) % 4;
  if (morseTotal < 4) morseTotal++;

  if (morseTotal == 4) {
    bool match = true;
    for (int i = 0; i < 4; i++) {
      int idx = (morseBufPos + i) % 4;
      if (userSequence[idx] != correctSequence[i]) { match = false; break; }
    }

    if (match) {
      morseSolved = true;
      for (int i = 0; i < 4; i++) digitalWrite(morseLeds[i], HIGH);
      digitalWrite(GREEN_LED_MORSE, HIGH);
      Serial.println("Morse solved!");
    }
  }
}

void playMorse() {
  unsigned long t = millis();

  if (inWordPause) {
    if (t - morseLastChange >= wordPause) {
      inWordPause = false;
      currentWord = (currentWord + 1) % 4;
      currentSymbol = 0;
      morseLastChange = t;
    }
    return;
  }

  char s = morseWords[currentWord][currentSymbol];
  if (s == '\0') {
    inWordPause = true;
    morseLastChange = t;
    return;
  }

  int duration = (s == '.') ? dotTime : dashTime;

  if (!morseLedOn && t - morseLastChange >= pauseTime) {
    digitalWrite(morseLeds[currentWord], HIGH);
    morseLedOn = true;
    morseLastChange = t;
  }

  if (morseLedOn && t - morseLastChange >= duration) {
    digitalWrite(morseLeds[currentWord], LOW);
    morseLedOn = false;
    morseLastChange = t;
    currentSymbol++;
  }
}

void updateMorseButtons() {
  static int lastState[4] = {HIGH,HIGH,HIGH,HIGH};
  static unsigned long lastChange[4] = {0,0,0,0};
  static bool latched[4] = {false,false,false,false};

  unsigned long now = millis();
  for (int i = 0; i < 4; i++) {
    int s = digitalRead(morseButtons[i]);
    if (s != lastState[i]) {
      lastState[i] = s;
      lastChange[i] = now;
    } else {
      if (s == LOW && !latched[i] && (now - lastChange[i] >= 25)) {
        latched[i] = true;
        registerInput(i + 1);
      } else if (s == HIGH) {
        latched[i] = false;
      }
    }
  }
}

void updateConfirmButton() {
  static int lastState = HIGH;
  static unsigned long lastChange = 0;
  static bool latched = false;

  unsigned long now = millis();
  int s = digitalRead(BTN_CONFIRM);

  if (s != lastState) {
    lastState = s;
    lastChange = now;
  } else {
    if (s == LOW && !latched && (now - lastChange >= 35)) {
      latched = true;
      if (!wordSolved) {
        char chosen[5];
        chosen[0] = options0[optIndex[0]];
        chosen[1] = options1[optIndex[1]];
        chosen[2] = options2[optIndex[2]];
        chosen[3] = options3[optIndex[3]];
        chosen[4] = '\0';

        if (strcmp(chosen, targetWord) == 0) {
          wordSolved = true;
          digitalWrite(GREEN_LED_PIN, HIGH);
          drawSolvedBorder();
          Serial.println("Correct!");
        }
      }
    } else if (s == HIGH) {
      latched = false;
    }
  }
}

void initMatrixJoystickMorseWord() {
  for (int i = 0; i < 4; i++) {
    pinMode(morseLeds[i], OUTPUT);
    pinMode(morseButtons[i], INPUT_PULLUP);
  }

  pinMode(BTN_CONFIRM, INPUT_PULLUP);
  pinMode(GREEN_LED_PIN, OUTPUT);
  pinMode(GREEN_LED_MORSE, OUTPUT);

  for (int i = 0; i < NUM_DEVICES; i++) {
    lc.shutdown(i, false);
    lc.setIntensity(i, 4);
    lc.clearDisplay(i);
  }

  displayWord();
}

void pollMatrixJoystickMorseWord() {
  updateMorseButtons();
  if (!morseSolved) playMorse();
  if (!wordSolved) handleJoystick();
  updateConfirmButton();
}

/* ===================== Setup / loop ===================== */

void setup() {
  Serial.begin(115200);
  unsigned long start = millis();
  while (!Serial && (millis() - start < 1500)) {}

  initPairSimon();
  initEncoderPuzzle();
  initMatrixJoystickMorseWord();

  Serial.println("All subsystems initialized.");
}

void loop() {
  updateBuzzer();
  pollPairSimon();
  pollEncoderPuzzle();
  pollMatrixJoystickMorseWord();
}
